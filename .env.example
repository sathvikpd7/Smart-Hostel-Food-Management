

# PostgreSQL Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=smart_hostel
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Server Configuration
PORT=3001

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# JWT Configuration
JWT_SECRET=your-secure-secret-key-change-in-production

# QR Code Signing Secret (for HMAC-signed QR codes)
QR_SIGNING_SECRET=your-qr-signing-secret-change-in-production

# Admin Credentials (for initialization)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# Sample user password for initDb seed script (development only)
SAMPLE_USER_PASSWORD=change-me-in-production

# Debug (optional)
DEBUG_DB=false


# Feature Flags
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_ENABLE_SENTIMENT_ANALYSIS=true
VITE_ENABLE_AI_MENU_PLANNING=true
VITE_ENABLE_MEAL_RECOMMENDATIONS=true
